# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Leave AUTH_USERNAME/AUTH_PASSWORD_HASH unset for local dev (no login screen).
# Set both to require login (e.g. on the VPS). Generate a hash with:
#   node -e "require('bcryptjs').hash(process.argv[1], 10).then(console.log)" "yourpassword"
AUTH_USERNAME=
AUTH_PASSWORD_HASH=

# Random string for signing session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Server port (defaults to 3001 if unset)
API_PORT=3001
